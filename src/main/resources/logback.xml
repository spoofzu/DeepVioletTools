<?xml version="1.0" encoding="UTF-8"?>
<!-- Minimal auto-configuration: no file appenders.
     The full config is in logback-default.xml and loaded by LogUtils.logInit()
     after setting the dv.log.dir system property. Without this stub, logback
     auto-configures from logback-default.xml before the property is set,
     creating a stray dv.log.dir_IS_UNDEFINED directory in the working dir. -->
<configuration>
  <root level="OFF" />
</configuration>
